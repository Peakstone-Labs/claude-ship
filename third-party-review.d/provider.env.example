# Third-party review provider profile — EXAMPLE.
# Copy to a real profile named <provider>.env (e.g. deepseek.env / kimi.env) and fill in.
# Any endpoint that speaks the Anthropic Messages API works (DeepSeek, Kimi/Moonshot, ...).
#
# The real *.env is gitignored — NEVER commit tokens. Only this .example is tracked.

# --- required ---
ANTHROPIC_BASE_URL=https://your-provider.example.com/anthropic   # third-party, Anthropic-compatible endpoint
ANTHROPIC_AUTH_TOKEN=sk-replace-with-your-token                  # the provider's API key
TPR_MODEL=your-model-id                                          # model the reviewer runs on

# --- optional: model routing for the headless sub-session ---
# ANTHROPIC_MODEL=your-model-id
# ANTHROPIC_DEFAULT_OPUS_MODEL=your-strong-model-id
# ANTHROPIC_DEFAULT_SONNET_MODEL=your-fast-model-id
# ANTHROPIC_DEFAULT_HAIKU_MODEL=your-cheap-model-id
